# Copy this file to `keystore.properties` and fill in real values.
# `keystore.properties` is gitignored — NEVER commit it or the keystore file.
# build-offline.sh injects these into the generated android/app/build.gradle
# so the release APK is signed with your own key instead of the debug key.

# Absolute path to your release keystore (also keep it OUT of the repo):
storeFile=/absolute/path/to/simpleday-release.keystore
storePassword=CHANGE_ME
keyAlias=simpleday
keyPassword=CHANGE_ME
